{
    "dependencies": {
        "@atproto/api": "^0.19.5",
        "adm-zip": "^0.5.17",
        "axios": "^1.16.1",
        "axios-cache-interceptor": "^1.12.0",
        "chalk": "^5.6.2",
        "cron": "^4.4.0",
        "dotenv": "^17.4.2",
        "express": "^5.2.1",
        "puppeteer": "^25.0.4",
        "sqlite3": "^6.0.1"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/express": "^5.0.0",
        "@vitest/coverage-v8": "^4.1.2",
        "eslint": "^10.1.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "globals": "^17.4.0",
        "husky": "^9.1.7",
        "lint-staged": "^17.0.8",
        "nodemon": "^3.1.14",
        "prettier": "^3.8.3",
        "ts-node": "^10.9.2",
        "typescript": "^6.0.2",
        "typescript-eslint": "^8.59.4",
        "vitest": "^4.1.2"
    },
    "scripts": {
        "start": "NODE_PATH=./build node build/index.js",
        "prod": "node build/index.js",
        "build": "tsc -p .",
        "dev": "BLUESKY_DEBUG=true nodemon src/index.ts",
        "test": "vitest run",
        "test:watch": "vitest",
        "lint": "eslint \"src/**/*.ts\" \"scripts/**/*.ts\"",
        "lint:fix": "eslint \"src/**/*.ts\" \"scripts/**/*.ts\" --fix",
        "format": "prettier \"src/**/*.ts\" \"scripts/**/*.ts\" \"*.{js,cjs,json,md,yml,yaml}\" --check",
        "format:write": "prettier \"src/**/*.ts\" \"scripts/**/*.ts\" \"*.{js,cjs,json,md,yml,yaml}\" --write",
        "install:browser": "npx puppeteer browsers install chrome",
        "create-aircraft-db": "ts-node scripts/create-aircraft-db.ts",
        "check-pelias-airport": "ts-node scripts/check-pelias-airport.ts",
        "prepare": "husky"
    }
}
