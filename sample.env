# Total heading change to detect a circling aircraft
TOTAL_CHANGE=1440 
# Time window for heading data in milliseconds
TIME_WINDOW=1500000 
# This should be the same time as the time window for data, or else you'll get repeat posts, determines when to prune old data
PRUNE_TIME=1500000 

# The Pelias instance used to reverse geocode
PELIAS_INSTANCE=http://pelias-instance:4000/v1/

# The Airplanes.live Endpoint. Add your GPS coords and radius /point/[lat]/[lon]/[radius]
TAR1090_DATA_URL=https://api.airplanes.live/v2/point/[lat]/[lon]/[radius] 

# The Airplanes.live UI to send links to
TAR1090_URL=https://globe.airplanes.live/ 

# BSky credentials
BLUESKY_USERNAME=
BLUESKY_PASSWORD=
# Set BLUESKY_DEBUG=true to skip posting and only print messages to the terminal.
# BLUESKY_DEBUG=true
# Or set BLUESKY_DRY_RUN=true to skip posting and print the message.
# BLUESKY_DRY_RUN=true

# Enable/disable detection jobs (set to false to turn off). Default both true.
# ENABLE_CIRCLING_DETECTION=true
# ENABLE_ZIGZAG_DETECTION=false

# Enable/disable aircraft photo attachment (airport-data.com). Default true.
# AIRCRAFT_PHOTO_ENABLED=true

# Data directory for both DBs (aircraft_info.db and aircraft.db). Default ./data. Docker sets DATA_DIR=/home/node/app/data.
# DATA_DIR=./data

